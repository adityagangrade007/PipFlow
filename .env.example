# --- Database (PostgreSQL — Neon recommended: https://neon.tech) ---
# Pooled connection string (used at runtime).
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
# Direct (non-pooled) connection string (used by `prisma migrate`).
# For local Postgres, set it to the same value as DATABASE_URL.
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# --- Auth.js (REQUIRED in production — sign-in fails without it) ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=""
# Only needed outside Vercel (Vercel sets the URL automatically).
# AUTH_URL="http://localhost:3000"

# --- Bridge layer (future phases) ---
# BRIDGE_PROVIDER="simulation"
